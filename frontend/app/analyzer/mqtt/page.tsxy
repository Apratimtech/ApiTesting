"use client";
import { useEffect, useState, useCallback, useRef } from "react";
import {
  Bolt,
  Link2,
  Send,
  Wand2,
  Bell,
  Upload,
  ShieldAlert,
  Activity,
  Clock3,
  Ban,
  Loader2,
  MessageCircle,
  Copy,
  Download,
  RefreshCw,
} from "lucide-react";

type LogType = "SYS" | "INFO" | "WARN" | "ERROR" | "IN" | "OUT";

type LogEntry = {
  id: string;
  type: LogType;
  message: string;
  topic?: string;
  timestamp: string;
};

type SecurityFinding = {
  severity: "LOW" | "MEDIUM" | "HIGH" | "CRITICAL";
  title: string;
  description: string;
  cwe?: string;
  owasp?: string;
};

type SessionMetrics = {
  messagesSent: number;
  messagesReceived: number;
  subscriptions: number;
  reconnectCount: number;
  sessionDuration: string;
};

export default function MQTTConsolePage() {
  const [connected, setConnected] = useState(false);
  const [connecting, setConnecting] = useState(false);
  const [loadingPublish, setLoadingPublish] = useState(false);
  const [loadingSubscribe, setLoadingSubscribe] = useState(false);
  const [loadingDisconnect, setLoadingDisconnect] = useState(false);
  const [reconnecting, setReconnecting] = useState(false);

  const [brokerUrl, setBrokerUrl] = useState("mqtts://broker.emqx.io:8883");
  const [clientId, setClientId] = useState("");
  const [username, setUsername] = useState("");
  const [password, setPassword] = useState("");
  const [topic, setTopic] = useState("devtools/test/topic");
  const [payload, setPayload] = useState(`{
  "device_id": "sensor_x42",
  "status": "active",
  "telemetry": {
    "temperature": 24.5,
    "humidity": 48.2,
    "units": "celsius"
  },
  "timestamp": ${Math.floor(Date.now() / 1000)}
}`);

  const [retain, setRetain] = useState(false);
  const [qos, setQos] = useState(1);

  const [logs, setLogs] = useState<LogEntry[]>([]);
  const [activeTab, setActiveTab] = useState<"logs" | "timing" | "security">("logs");
  const [latency, setLatency] = useState("--");
  const [riskScore, setRiskScore] = useState(0);
  const [securityFindings, setSecurityFindings] = useState<SecurityFinding[]>([]);
  const [metrics, setMetrics] = useState<SessionMetrics>({
    messagesSent: 0,
    messagesReceived: 0,
    subscriptions: 0,
    reconnectCount: 0,
    sessionDuration: "00:00",
  });

  const logsEndRef = useRef<HTMLDivElement>(null);
  const pollIntervalRef = useRef<NodeJS.Timeout | null>(null);
  const sessionStartRef = useRef<Date | null>(null);
  const reconnectAttemptsRef = useRef(0);
  const processedMessagesRef = useRef(new Set<string>());
  const connectedRef = useRef(false);
  const MAX_RETRIES = 5;

  const BACKEND_URL = process.env.NEXT_PUBLIC_BACKEND_URL || "http://127.0.0.1:8000";

  const addLog = useCallback((type: LogType, message: string, topic?: string) => {
    const timestamp = new Date().toLocaleTimeString([], { hour12: false });
    const newLog: LogEntry = {
      id: crypto.randomUUID(),
      type,
      message,
      topic,
      timestamp,
    };
    setLogs((prev) => [...prev.slice(-200), newLog]);
  }, []);

  const maskSensitiveData = (text: string): string => {
    let masked = text;
    masked = masked.replace(
      /("?(password|token|secret|api[_-]?key|auth|credential)"?\s*:\s*["'])([^"']+)(["'])/gi,
      "$1********$4"
    );
    masked = masked.replace(/eyJ[A-Za-z0-9_-]+\.eyJ[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+/g, "eyJ...[JWT]");
    return masked;
  };

  const callBackend = async (
    endpoint: string,
    body: any = {},
    timeoutMs = 15000,
    method: "GET" | "POST" | "DELETE" = "POST"
  ) => {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), timeoutMs);

    try {
      const fetchOptions: RequestInit = {
        method,
        headers: { "Content-Type": "application/json" },
        signal: controller.signal,
      };

      if (method !== "GET" && method !== "DELETE") {
        fetchOptions.body = JSON.stringify(body);
      }

      const res = await fetch(`${BACKEND_URL}/api/v1/mqtt/${endpoint}`, fetchOptions);
      clearTimeout(timeoutId);

      let data;
      try {
        data = await res.json();
      } catch {
        data = { success: false, message: "Invalid JSON response from server" };
      }

      if (!res.ok) {
        let errorMsg = "Request failed";
        if (typeof data?.detail === "string") errorMsg = data.detail;
        else if (typeof data?.message === "string") errorMsg = data.message;
        else if (data?.detail) errorMsg = JSON.stringify(data.detail);
        throw new Error(errorMsg);
      }

      return data;
    } catch (err: any) {
      clearTimeout(timeoutId);
      if (err.name === "AbortError") throw new Error("Request timed out");
      console.error(`[MQTT ${endpoint.toUpperCase()}] Error:`, err);
      addLog("ERROR", err.message || "Backend request failed");
      return { success: false, message: err.message || "Backend request failed" };
    }
  };

  const updateAnalysisUI = useCallback((data: any) => {
    if (data.success) {
      const rawLatency = data.latency;
      const sanitizedLatency = rawLatency && typeof rawLatency === "object"
        ? String(rawLatency.value || JSON.stringify(rawLatency))
        : String(rawLatency || "--");
      setLatency(sanitizedLatency);

      const rawRisk = data.riskScore && typeof data.riskScore === "object"
        ? Number(data.riskScore.value || 0)
        : Number(data.riskScore || 0);
      setRiskScore(Math.max(0, Math.min(rawRisk, 100)));

      const rawFindings = data.securityFindings || [];
      const sanitizedFindings = rawFindings.map((finding: any) => {
        const title = finding.title && typeof finding.title === "object"
          ? String(finding.title.value || JSON.stringify(finding.title))
          : String(finding.title || "Unknown Issue");

        const description = finding.description && typeof finding.description === "object"
          ? String(finding.description.value || JSON.stringify(finding.description))
          : String(finding.description || "No description provided.");

        const cwe = finding.cwe && typeof finding.cwe === "object"
          ? String(finding.cwe.value || JSON.stringify(finding.cwe))
          : finding.cwe ? String(finding.cwe) : undefined;

        const owasp = finding.owasp && typeof finding.owasp === "object"
          ? String(finding.owasp.value || JSON.stringify(finding.owasp))
          : finding.owasp ? String(finding.owasp) : undefined;

        return {
          severity: finding.severity || "MEDIUM",
          title,
          description,
          cwe,
          owasp
        };
      });

      setSecurityFindings(sanitizedFindings.slice(0, 100));
    }
  }, []);

  const validateBrokerUrl = (url: string) => {
    try {
      let processedUrl = url.trim();
      if (
        !processedUrl.startsWith("mqtt://") &&
        !processedUrl.startsWith("mqtts://") &&
        !processedUrl.startsWith("ws://") &&
        !processedUrl.startsWith("wss://")
      ) {
        processedUrl = `mqtts://${processedUrl}`;
      }
      const parsed = new URL(processedUrl);
      return {
        valid: true,
        host: parsed.hostname,
        port: Number(parsed.port) || (parsed.protocol === "mqtts:" || parsed.protocol === "wss:" ? 8883 : 1883),
        isSecure: parsed.protocol === "mqtts:" || parsed.protocol === "wss:",
      };
    } catch {
      return { valid: false, error: "Invalid broker URL", isSecure: false };
    }
  };

  const validatePayload = (payloadStr: string): boolean => {
    if (!payloadStr.trim()) return true;
    try {
      JSON.parse(payloadStr);
      return true;
    } catch {
      addLog("WARN", "Invalid JSON payload. Please fix or use Beautify JSON.");
      return false;
    }
  };

  useEffect(() => { connectedRef.current = connected; }, [connected]);

  useEffect(() => {
    let timer: NodeJS.Timeout | null = null;
    if (connected && sessionStartRef.current) {
      timer = setInterval(() => {
        const durationMs = Date.now() - sessionStartRef.current!.getTime();
        const minutes = Math.floor(durationMs / 60000);
        const seconds = Math.floor((durationMs % 60000) / 1000);
        setMetrics((prev) => ({
          ...prev,
          sessionDuration: `${minutes.toString().padStart(2, "0")}:${seconds.toString().padStart(2, "0")}`,
        }));
      }, 1000);
    }
    return () => { if (timer) clearInterval(timer); };
  }, [connected]);

  const updateSessionMetrics = useCallback((isIncoming = false) => {
    setMetrics((prev) => ({
      ...prev,
      messagesSent: isIncoming ? prev.messagesSent : prev.messagesSent + 1,
      messagesReceived: isIncoming ? prev.messagesReceived + 1 : prev.messagesReceived,
    }));
  }, []);

  // Fixed startPolling - moved after function definitions to avoid hoisting error
  const startPolling = useCallback(() => {
    if (pollIntervalRef.current) clearInterval(pollIntervalRef.current);

    pollIntervalRef.current = setInterval(async () => {
      if (!connectedRef.current) return;

      try {
        const status = await callBackend("status", {}, 5000, "GET");
        if (!status.success || !status.data?.connected) {
          if (reconnectAttemptsRef.current >= MAX_RETRIES) {
            addLog("ERROR", "Maximum reconnect attempts reached. Please reconnect manually.");
            await disconnectBroker(true);
            return;
          }
          reconnectAttemptsRef.current += 1;
          setReconnecting(true);
          addLog("WARN", `Connection lost. Reconnecting... (${reconnectAttemptsRef.current}/${MAX_RETRIES})`);
          await disconnectBroker(true);
          setTimeout(() => connectBroker(true), 1500);
          return;
        }

        const msgRes = await callBackend("messages", {}, 5000, "GET");
        if (msgRes.success && Array.isArray(msgRes.messages)) {
          msgRes.messages.forEach((msg: any) => {
            const key = `${msg.timestamp || Date.now()}-${msg.topic}`;
            if (processedMessagesRef.current.has(key)) return;

            processedMessagesRef.current.add(key);

            let stringPayload = "";
            if (msg.payload && typeof msg.payload === "object") {
              stringPayload = msg.payload.value ? String(msg.payload.value) : JSON.stringify(msg.payload);
            } else {
              stringPayload = String(msg.payload || "");
            }

            const masked = maskSensitiveData(stringPayload);
            addLog("IN", masked, msg.topic);
          });

          if (msgRes.messages.length > 0) {
            setMetrics((prev) => ({
              ...prev,
              messagesReceived: prev.messagesReceived + msgRes.messages.length,
            }));
          }
        }
      } catch {
        // Silent for polling
      }
    }, 5000);
  }, [addLog, connectBroker, disconnectBroker]);

  const connectBroker = async (isReconnect = false) => {
    if (connecting) return;
    setConnecting(true);
    if (!isReconnect) addLog("INFO", `Requesting connection to ${brokerUrl}`);

    if (!topic?.trim()) {
      addLog("ERROR", "Topic is required for connection");
      setConnecting(false);
      return;
    }

    const validation = validateBrokerUrl(brokerUrl);

    console.log("=== CONNECT DEBUG ===");
    console.log("Raw Broker URL:", brokerUrl);
    console.log("Validation Result:", validation);
    console.log("Sending to backend:", {
      broker_host: validation.host,
      broker_port: validation.port,
      tls_enabled: validation.isSecure,
    });
    console.log("=====================");

    if (!validation.valid) {
      addLog("ERROR", validation.error || "Invalid broker URL");
      setConnecting(false);
      return;
    }

    try {
      const res = await callBackend("connect", {
        broker_host: validation.host,
        broker_port: validation.port,
        protocol: validation.isSecure ? "wss" : "mqtt",
        client_id: clientId || `trustedge_${Math.random().toString(16).slice(2, 10)}`,
        username,
        password,
        tls_enabled: validation.isSecure,
        tls_insecure: false,
        subscribe_topics: [topic],
        qos,
      });

      if (res.success) {
        setConnected(true);
        sessionStartRef.current = new Date();
        reconnectAttemptsRef.current = 0;
        processedMessagesRef.current.clear();
        updateAnalysisUI(res);
        addLog("SYS", isReconnect ? "✅ Reconnected successfully" : "✅ Backend connection established successfully");
        startPolling();
        if (isReconnect) {
          setReconnecting(false);
          setMetrics((prev) => ({ ...prev, reconnectCount: prev.reconnectCount + 1 }));
        }
      } else {
        addLog("ERROR", res.message || "Connection failed");
      }
    } catch (err: any) {
      addLog("ERROR", err.message);
    } finally {
      setConnecting(false);
    }
  };

  const disconnectBroker = async (silent = false) => {
    if (loadingDisconnect) return;
    setLoadingDisconnect(true);
    try {
      await callBackend("disconnect", { reason: "Frontend disconnect" });
      if (!silent) addLog("SYS", "Disconnected from MQTT broker");
    } catch (err: any) {
      if (!silent) addLog("ERROR", err.message);
    } finally {
      setConnected(false);
      setReconnecting(false);
      setLoadingDisconnect(false);
      setRiskScore(0);
      setSecurityFindings([]);
      setLatency("--");
      setMetrics({
        messagesSent: 0,
        messagesReceived: 0,
        subscriptions: 0,
        reconnectCount: 0,
        sessionDuration: "00:00",
      });
      if (pollIntervalRef.current) {
        clearInterval(pollIntervalRef.current);
        pollIntervalRef.current = null;
      }
      sessionStartRef.current = null;
      reconnectAttemptsRef.current = 0;
      processedMessagesRef.current.clear();
    }
  };

  const publishMessage = async () => {
    if (!connected) { addLog("ERROR", "Cannot publish - not connected"); return; }
    if (!topic.trim()) { addLog("ERROR", "Topic is required"); return; }
    if (!validatePayload(payload)) return;
    if (payload.length > 50000) { addLog("WARN", "Payload too large (>50KB). Consider reducing size."); return; }

    setLoadingPublish(true);
    try {
      const res = await callBackend("publish", { topic, payload, qos, retain });
      if (res.success) {
        const maskedPayload = maskSensitiveData(payload);
        addLog("OUT", maskedPayload, topic);
        updateAnalysisUI(res);
        updateSessionMetrics();
      } else {
        addLog("ERROR", res.message || "Publish failed");
      }
    } catch (err: any) {
      addLog("ERROR", err.message);
    } finally {
      setLoadingPublish(false);
    }
  };

  const subscribeTopic = async () => {
    if (!connected) { addLog("ERROR", "Cannot subscribe - not connected"); return; }
    if (!topic.trim()) { addLog("ERROR", "Topic is required"); return; }
    if (topic.includes("###") || topic.includes("++++") || (topic.match(/#/g) || []).length > 2) {
      addLog("WARN", "Broad wildcard topic detected. This may expose excessive data.");
    }
    setLoadingSubscribe(true);
    try {
      const res = await callBackend("subscribe", { topics: [topic], qos });
      if (res.success) {
        addLog("SYS", `Subscribed to ${topic}`);
        updateAnalysisUI(res);
        setMetrics((prev) => ({ ...prev, subscriptions: prev.subscriptions + 1 }));
      } else {
        addLog("ERROR", res.message || "Subscribe failed");
      }
    } catch (err: any) {
      addLog("ERROR", err.message);
    } finally {
      setLoadingSubscribe(false);
    }
  };

  const beautifyJSON = () => {
    try {
      const parsed = JSON.parse(payload);
      setPayload(JSON.stringify(parsed, null, 2));
      addLog("INFO", "Payload beautified successfully");
    } catch {
      addLog("ERROR", "Invalid JSON payload");
    }
  };

  const clearLogs = () => {
    setLogs([]);
    processedMessagesRef.current.clear();
    addLog("INFO", "Logs cleared");
  };

  const copyLog = async (log: LogEntry) => {
    try {
      const text = `[${log.timestamp}] ${log.type} ${log.topic ? `[${log.topic}]` : ""} ${log.message}`;
      await navigator.clipboard.writeText(text);
      addLog("INFO", "Log copied to clipboard");
    } catch {
      addLog("ERROR", "Failed to copy log (clipboard permission issue)");
    }
  };

  const exportFindings = () => {
    if (securityFindings.length === 0) {
      addLog("INFO", "No findings to export");
      return;
    }
    const report = {
      timestamp: new Date().toISOString(),
      riskScore,
      metrics,
      findings: securityFindings,
    };
    const dataStr = JSON.stringify(report, null, 2);
    const blob = new Blob([dataStr], { type: "application/json" });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.href = url;
    link.download = `mqtt-security-report-${new Date().toISOString().slice(0, 10)}.json`;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    URL.revokeObjectURL(url);
    addLog("INFO", "Security report exported");
  };

  useEffect(() => {
    return () => {
      if (pollIntervalRef.current) clearInterval(pollIntervalRef.current);
    };
  }, []);

  useEffect(() => {
    const defaultClientId = `trustedge_${Math.random().toString(16).slice(2, 10)}`;
    setClientId(defaultClientId);

    addLog("SYS", "TrustEdge MQTT Analyzer initialized");
    addLog("INFO", "Frontend connected to backend validation layer");
  }, [addLog]);

  const riskLabel = (() => {
    if (riskScore >= 80) return "CRITICAL";
    if (riskScore >= 60) return "HIGH";
    if (riskScore >= 30) return "MEDIUM";
    return "LOW";
  })();

  const riskColor = riskScore >= 80 ? "text-red-400" : riskScore >= 60 ? "text-orange-400" : riskScore >= 30 ? "text-yellow-400" : "text-cyan-300";

  return (
    <main className="min-h-screen bg-[#03101f] text-[#d9e7ff]">
      <div className="p-6 max-w-[1600px] mx-auto">
        {/* Header */}
        <div className="flex items-center gap-4 mb-10">
          <div className="w-14 h-14 rounded-xl bg-gradient-to-br from-cyan-400 to-purple-600 flex items-center justify-center shadow-[0_0_30px_rgba(139,92,246,0.5)]">
            <Bolt className="w-7 h-7 text-black" />
          </div>
          <div>
            <h1 className="text-5xl font-extrabold bg-gradient-to-r from-cyan-300 to-purple-400 bg-clip-text text-transparent">
              TrustEdge MQTT Console
            </h1>
            <div className="flex items-center gap-2 mt-2">
              <span className={`w-2 h-2 rounded-full ${connected ? "bg-cyan-400 animate-pulse" : "bg-red-400"}`} />
              <span className={`text-xs uppercase tracking-[0.2em] font-bold ${connected ? "text-cyan-300" : "text-red-300"}`}>
                {connecting ? "CONNECTING..." : reconnecting ? "RECONNECTING..." : connected ? "CONNECTED" : "DISCONNECTED"}
              </span>
            </div>
          </div>
        </div>

        <div className="grid grid-cols-12 gap-6">
          {/* LEFT - Connection Settings */}
          <section className="col-span-12 lg:col-span-5 rounded-2xl border border-cyan-400/20 bg-[#07172b]/80 backdrop-blur-xl p-6">
            <div className="flex items-center justify-between border-b border-white/10 pb-4 mb-6">
              <div className="flex items-center gap-3">
                <Link2 className="w-5 h-5 text-cyan-300" />
                <h2 className="text-3xl font-bold">Connection Settings</h2>
              </div>
              <div className="px-3 py-1 rounded-full text-xs border border-cyan-400/20 bg-cyan-400/10 text-cyan-300">
                BACKEND VALIDATED
              </div>
            </div>
            <div className="space-y-5">
              <div>
                <label className="text-xs uppercase text-gray-400 block mb-2">Broker URL</label>
                <input
                  value={brokerUrl}
                  onChange={(e) => setBrokerUrl(e.target.value)}
                  className="w-full bg-[#0b1d33] border border-white/10 rounded-xl p-4 outline-none focus:border-cyan-400"
                  placeholder="mqtts://broker.emqx.io:8883"
                />
              </div>
              <div>
                <label className="text-xs uppercase text-gray-400 block mb-2">Client ID</label>
                <input
                  value={clientId}
                  onChange={(e) => setClientId(e.target.value)}
                  className="w-full bg-[#0b1d33] border border-white/10 rounded-xl p-4 outline-none focus:border-cyan-400"
                />
              </div>
              <div className="grid grid-cols-2 gap-4">
                <div>
                  <label className="text-xs uppercase text-gray-400 block mb-2">Username</label>
                  <input value={username} onChange={(e) => setUsername(e.target.value)} className="w-full bg-[#0b1d33] border border-white/10 rounded-xl p-4 outline-none" />
                </div>
                <div>
                  <label className="text-xs uppercase text-gray-400 block mb-2">Password</label>
                  <input type="password" value={password} onChange={(e) => setPassword(e.target.value)} className="w-full bg-[#0b1d33] border border-white/10 rounded-xl p-4 outline-none" />
                </div>
              </div>
              <div className="grid grid-cols-2 gap-4">
                <div>
                  <label className="text-xs uppercase text-gray-400 block mb-2">QoS Level</label>
                  <select value={qos} onChange={(e) => setQos(Number(e.target.value))} className="w-full bg-[#0b1d33] border border-white/10 rounded-xl p-4 outline-none">
                    <option value={0}>QoS 0</option>
                    <option value={1}>QoS 1</option>
                    <option value={2}>QoS 2</option>
                  </select>
                </div>
                <div className="flex items-end">
                  <button onClick={() => setRetain((prev) => !prev)} className={`w-full p-4 rounded-xl border transition-all ${retain ? "bg-cyan-400/20 border-cyan-400 text-cyan-300" : "bg-[#0b1d33] border-white/10"}`}>
                    Retain: {retain ? "Enabled" : "Disabled"}
                  </button>
                </div>
              </div>
              <div className="grid grid-cols-4 gap-4 pt-3">
                <button
                  onClick={() => connectBroker(false)}
                  disabled={connecting || connected}
                  className="col-span-3 py-4 rounded-xl bg-gradient-to-r from-cyan-400 to-purple-500 text-black font-bold hover:brightness-110 transition-all disabled:opacity-70 flex items-center justify-center gap-2"
                >
                  {connecting && <Loader2 className="w-5 h-5 animate-spin" />}
                  {connecting ? "Connecting..." : "Connect Broker"}
                </button>
                <button
                  onClick={() => disconnectBroker(false)}
                  disabled={!connected || loadingDisconnect}
                  className="border border-red-400/20 rounded-xl text-red-300 hover:bg-red-400/10 transition-all disabled:opacity-50 flex items-center justify-center"
                >
                  {loadingDisconnect ? <Loader2 className="w-4 h-4 animate-spin" /> : "Disconnect"}
                </button>
              </div>
            </div>
          </section>

          {/* RIGHT - Publish Message */}
          <section className="col-span-12 lg:col-span-7 rounded-2xl border border-purple-400/20 bg-[#07172b]/80 backdrop-blur-xl p-6">
            <div className="flex items-center justify-between border-b border-white/10 pb-4 mb-6">
              <div className="flex items-center gap-3">
                <Send className="w-5 h-5 text-purple-300" />
                <h2 className="text-3xl font-bold">Publish Message</h2>
              </div>
              <button onClick={beautifyJSON} className="flex items-center gap-2 text-cyan-300 hover:text-white">
                <Wand2 className="w-4 h-4" /> Beautify JSON
              </button>
            </div>
            <div className="space-y-5">
              <div>
                <label className="text-xs uppercase text-gray-400 block mb-2">Topic</label>
                <input value={topic} onChange={(e) => setTopic(e.target.value)} className="w-full bg-[#0b1d33] border border-white/10 rounded-xl p-4 outline-none focus:border-purple-400" />
              </div>
              <div>
                <label className="text-xs uppercase text-gray-400 block mb-2">Message Payload</label>
                <textarea
                  value={payload}
                  onChange={(e) => setPayload(e.target.value)}
                  spellCheck={false}
                  className="w-full min-h-[320px] bg-[#020b18] border border-white/10 rounded-xl p-5 font-mono text-sm outline-none resize-none text-cyan-100"
                />
              </div>
              <div className="grid grid-cols-4 gap-4">
                <button
                  onClick={publishMessage}
                  disabled={loadingPublish || !connected}
                  className="col-span-3 py-4 rounded-xl bg-[#d7b6ff] text-purple-900 font-bold flex items-center justify-center gap-2 hover:brightness-110 disabled:opacity-70"
                >
                  {loadingPublish && <Loader2 className="w-5 h-5 animate-spin" />}
                  <Upload className="w-4 h-4" />
                  Publish
                </button>
                <button
                  onClick={subscribeTopic}
                  disabled={loadingSubscribe || !connected}
                  className="rounded-xl border border-white/10 bg-[#16273b] hover:bg-[#22354a] transition-all flex items-center justify-center gap-2 disabled:opacity-70"
                >
                  {loadingSubscribe && <Loader2 className="w-4 h-4 animate-spin" />}
                  <Bell className="w-4 h-4" />
                  Subscribe
                </button>
              </div>
            </div>
          </section>

          {/* BOTTOM SECTION */}
          <section className="col-span-12 grid grid-cols-12 gap-6">
            <div className="col-span-12 lg:col-span-3 rounded-2xl border border-white/10 bg-[#07172b]/80 backdrop-blur-xl p-6">
              <div className="text-center">
                <p className="text-xs uppercase tracking-[0.2em] text-gray-400 mb-8">Overall Security Risk</p>
                <div className="w-40 h-40 mx-auto rounded-full border-[10px] border-cyan-200/20 flex items-center justify-center relative">
                  <div className="text-center">
                    <div className={`text-6xl font-extrabold ${riskColor}`}>{riskScore}</div>
                  </div>
                </div>
                <div className="mt-6 inline-flex px-4 py-2 rounded-full bg-cyan-400/10 border border-cyan-400/20 text-cyan-200 text-sm font-bold uppercase">
                  {riskLabel} Risk Environment
                </div>
              </div>
            </div>

            <div className="col-span-12 lg:col-span-9 rounded-2xl border border-white/10 bg-[#07172b]/80 backdrop-blur-xl overflow-hidden">
              <div className="flex items-center justify-between px-6 py-4 border-b border-white/10">
                <div className="flex items-center gap-6">
                  <button onClick={() => setActiveTab("logs")} className={`text-sm font-bold ${activeTab === "logs" ? "text-cyan-300" : "text-gray-400"}`}>Live Logs</button>
                  <button onClick={() => setActiveTab("timing")} className={`text-sm font-bold ${activeTab === "timing" ? "text-cyan-300" : "text-gray-400"}`}>Session Metrics</button>
                  <button onClick={() => setActiveTab("security")} className={`text-sm font-bold flex items-center gap-1 ${activeTab === "security" ? "text-cyan-300" : "text-gray-400"}`}>
                    Security Scan
                    {securityFindings.length > 0 && <span className="text-xs bg-red-500/80 text-white px-1.5 py-0.5 rounded-full">{securityFindings.length}</span>}
                  </button>
                </div>
                <div className="flex items-center gap-3">
                  <button onClick={exportFindings} className="text-gray-400 hover:text-cyan-300"><Download className="w-4 h-4" /></button>
                  <button onClick={clearLogs} className="text-gray-400 hover:text-red-300"><Ban className="w-4 h-4" /></button>
                </div>
              </div>

              <div className="h-[420px] overflow-auto p-6 font-mono text-sm relative">
                {activeTab === "logs" && (
                  <div className="space-y-3">
                    {logs.map((log) => (
                      <div key={log.id} className="flex gap-3 border-b border-white/5 pb-2 group">
                        <span className="text-white/30 whitespace-nowrap">[{log.timestamp}]</span>
                        <span className={`font-bold w-[60px] ${log.type === "ERROR" ? "text-red-300" : log.type === "WARN" ? "text-yellow-300" : log.type === "OUT" ? "text-purple-300" : log.type === "IN" ? "text-cyan-300" : "text-white"}`}>
                          {log.type}
                        </span>
                        {log.topic && <span className="text-cyan-300">[{log.topic}]</span>}
                        <span className="text-gray-300 break-all flex-1">
                          {typeof log.message === "object" ? JSON.stringify(log.message) : String(log.message || "")}
                        </span>
                        <button onClick={() => copyLog(log)} className="opacity-0 group-hover:opacity-100 text-gray-500 hover:text-white transition-all">
                          <Copy className="w-4 h-4" />
                        </button>
                      </div>
                    ))}
                    <div ref={logsEndRef} />
                    {logs.length === 0 && <div className="text-center text-gray-500 py-12">No logs yet. Connect and start publishing.</div>}
                  </div>
                )}

                {activeTab === "timing" && (
                  <div className="space-y-4">
                    <div className="rounded-xl bg-black/20 border border-white/10 p-5 flex items-center gap-4">
                      <Clock3 className="w-6 h-6 text-cyan-300" />
                      <div>
                        <p className="text-sm text-gray-400">Session Duration</p>
                        <p className="text-3xl font-bold text-cyan-300">{metrics.sessionDuration}</p>
                      </div>
                    </div>
                    <div className="grid grid-cols-2 gap-4">
                      <div className="rounded-xl bg-black/20 border border-white/10 p-5 flex items-center gap-4">
                        <Upload className="w-6 h-6 text-purple-300" />
                        <div>
                          <p className="text-sm text-gray-400">Messages Sent</p>
                          <p className="text-3xl font-bold text-purple-300">{metrics.messagesSent}</p>
                        </div>
                      </div>
                      <div className="rounded-xl bg-black/20 border border-white/10 p-5 flex items-center gap-4">
                        <MessageCircle className="w-6 h-6 text-cyan-300" />
                        <div>
                          <p className="text-sm text-gray-400">Messages Received</p>
                          <p className="text-3xl font-bold text-cyan-300">{metrics.messagesReceived}</p>
                        </div>
                      </div>
                    </div>
                    <div className="rounded-xl bg-black/20 border border-white/10 p-5 flex items-center gap-4">
                      <Activity className="w-6 h-6 text-emerald-300" />
                      <div>
                        <p className="text-sm text-gray-400">Active Subscriptions</p>
                        <p className="text-3xl font-bold text-emerald-300">{metrics.subscriptions}</p>
                      </div>
                    </div>
                    <div className="rounded-xl bg-black/20 border border-white/10 p-5 flex items-center gap-4">
                      <Clock3 className="w-6 h-6 text-cyan-300" />
                      <div>
                        <p className="text-sm text-gray-400">Last Latency</p>
                        <p className="text-3xl font-bold text-cyan-300">
                          {typeof latency === "object" ? JSON.stringify(latency) : String(latency)}
                        </p>
                      </div>
                    </div>
                    {metrics.reconnectCount > 0 && (
                      <div className="rounded-xl bg-black/20 border border-white/10 p-5 flex items-center gap-4">
                        <RefreshCw className="w-6 h-6 text-amber-300" />
                        <div>
                          <p className="text-sm text-gray-400">Reconnects</p>
                          <p className="text-3xl font-bold text-amber-300">{metrics.reconnectCount}</p>
                        </div>
                      </div>
                    )}
                  </div>
                )}

                {activeTab === "security" && (
                  <div className="space-y-4">
                    {securityFindings.length === 0 ? (
                      <div className="text-center py-16 text-gray-400">
                        <ShieldAlert className="w-12 h-12 mx-auto mb-4 opacity-50" />
                        No security findings detected.<br />Your configuration looks secure.
                      </div>
                    ) : (
                      securityFindings.map((finding, index) => (
                        <div key={index} className="rounded-xl border border-white/10 bg-black/20 p-5">
                          <div className="flex items-center justify-between mb-3">
                            <div className="flex items-center gap-3">
                              <ShieldAlert className="w-5 h-5 text-red-300" />
                              <h3 className="font-bold text-lg">{finding.title}</h3>
                            </div>
                            <span className={`px-3 py-1 rounded-full text-xs font-bold ${finding.severity === "CRITICAL" ? "bg-red-400/10 text-red-300" : finding.severity === "HIGH" ? "bg-orange-400/10 text-orange-300" : finding.severity === "MEDIUM" ? "bg-purple-400/10 text-purple-300" : "bg-cyan-400/10 text-cyan-300"}`}>
                              {finding.severity}
                            </span>
                          </div>
                          <p className="text-gray-400 leading-relaxed">{finding.description}</p>
                        </div>
                      ))
                    )}
                  </div>
                )}
              </div>
            </div>
          </section>
        </div>
      </div>

      {connected && (
        <div className="fixed bottom-6 right-6 bg-emerald-500/10 border border-emerald-500 text-emerald-400 px-4 py-2 rounded-2xl text-sm flex items-center gap-2 shadow-lg">
          <MessageCircle className="w-4 h-4" />
          Live MQTT Session Active
        </div>
      )}
    </main>
  );
}
